{
  "title": "KEDA ScaledObjects",
  "uid": "y2ks-keda",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "ScaledObject - Current Replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "keda_scaler_metrics_value",
          "legendFormat": "{{scaler}} / {{scaledObject}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "ScaledObject - Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "keda_scaled_object_paused",
          "legendFormat": "{{scaledObject}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "SQS Queue Length (y2ks-queue)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "keda_scaler_metrics_value{scaler=\"awsSqsQueue\"}",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Worker Replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas{deployment=\"y2ks-worker\"}",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_spec_replicas{deployment=\"y2ks-worker\"}",
          "legendFormat": "Desired",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "KEDA Operator - Errors",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(keda_scaler_errors_total[5m])",
          "legendFormat": "{{scaledObject}} errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "KEDA - ScaledObject Reconcile Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(keda_internal_scale_loop_latency_bucket[5m]))",
          "legendFormat": "p99 latency",
          "refId": "A"
        }
      ]
    }
  ]
}

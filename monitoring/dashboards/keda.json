{
  "title": "KEDA ScaledObjects",
  "uid": "y2ks-keda",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "ScaledObject - Current Replicas",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max by (scaledObject) (keda_scaler_metrics_value)",
          "legendFormat": "{{scaledObject}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "ScaledObject - Active",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max by (scaledObject) (keda_scaler_active)",
          "legendFormat": "{{scaledObject}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "SQS Queue Depth (y2ks-queue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max(keda_scaler_metrics_value{scaler=\"awsSqsQueueScaler\"})",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Worker Replicas",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max(kube_deployment_status_replicas{deployment=\"y2ks-worker\"})",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max(kube_deployment_spec_replicas{deployment=\"y2ks-worker\"})",
          "legendFormat": "Desired",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "KEDA Operator - Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "sum by (scaledObject) (rate(keda_scaler_detail_errors_total[5m]))",
          "legendFormat": "{{scaledObject}} errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "KEDA - ScaledObject Reconcile Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "AMP-y2ks" },
          "expr": "max(keda_internal_scale_loop_latency_seconds)",
          "legendFormat": "latency",
          "refId": "A"
        }
      ]
    }
  ]
}
